{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "115a359b236e40b9978b5d5bcad7dda5",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "DitherMonoBayer4x4 (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -634.0,
            "y": 623.0,
